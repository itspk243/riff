# Secrets — never commit these. The deploy script reads them locally and
# pushes them to Vercel as encrypted env vars.
.env
.env.local
.env.*.local
.env.deploy

# Node / Next
node_modules/
.next/
out/
dist/
build/

# Macros
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Vercel
.vercel/

# Extension build output. The bundle goes to dist/ at repo root — NEVER under
# backend/public/ — so it can't be served at a public URL. We upload this zip
# manually to the Chrome Web Store dev console.
backend/public/riff-extension.zip
backend/public/*.zip

# Build artifacts
riffly-extension-*.zip
zi[A-Za-z0-9]*

