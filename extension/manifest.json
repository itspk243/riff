{
  "manifest_version": 3,
  "name": "Riff — Personalized Outreach Drafts",
  "version": "0.6.0",
  "description": "Turn a candidate's profile (LinkedIn, GitHub, Wellfound) into a personalized cold-message draft. Drafting assistant only — no automation.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://github.com/*",
    "https://wellfound.com/*",
    "https://www.wellfound.com/*",
    "https://angel.co/*",
    "https://riff-sandy.vercel.app/*",
    "https://*.riff-sandy.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://www.linkedin.com/sales/lead/*",
        "https://www.linkedin.com/talent/profile/*",
        "https://github.com/*",
        "https://wellfound.com/u/*",
        "https://www.wellfound.com/u/*",
        "https://wellfound.com/profile/*",
        "https://www.wellfound.com/profile/*",
        "https://angel.co/u/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://riff-sandy.vercel.app/dashboard*",
        "https://riff-sandy.vercel.app/auth/callback*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Riff — Draft outreach"
  }
}
